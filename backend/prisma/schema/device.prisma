model Device {
  id                Int            @id @default(autoincrement())
  inventoryNumber   String         @unique
  serialNumber      String?
  name              String
  model             String?
  manufacturer      String?
  countryOfOrigin   String?
  yearMade          Int?

  riskClass         RiskClass?
  ceMarking         String?
  cndCode           String?

  status            DeviceStatus   @default(FUNCTIONAL)
  acquisitionDate   DateTime?      @db.Timestamptz(3)
  warrantyEndDate   DateTime?      @db.Timestamptz(3)
  decommissionDate  DateTime?      @db.Timestamptz(3)

  acquisitionValue  Decimal?
  residualValue     Decimal?
  currency          String         @default("MDL")

  voltage           String?
  frequency         String?
  power             String?
  accessories       String?

  maintenanceFreq   Int?
  nextMaintenanceAt DateTime?      @db.Timestamptz(3)
  lastMaintenanceAt DateTime?      @db.Timestamptz(3)

  sectionId         Int?
  section           Section?       @relation(fields: [sectionId], references: [id])
  room              String?

  manualUrl         String?
  certificateUrl    String?
  invoiceUrl        String?
  passportUrl       String?

  notes             String?
  createdById       Int?
  createdBy         User?          @relation("DeviceCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  maintenanceRecords MaintenanceRecord[]
  incidents          Incident[]
  consumables        DeviceConsumable[]

  @@index([inventoryNumber])
  @@index([status])
  @@index([sectionId])
  @@index([nextMaintenanceAt])
  @@map("devices")
}

model Consumable {
  id              Int       @id @default(autoincrement())
  name            String
  model           String?
  manufacturer    String?
  unitOfMeasure   String    @default("buc")
  quantity        Int       @default(0)
  minQuantity     Int       @default(0)
  expiryDate      DateTime? @db.Timestamptz(3)
  location        String?
  notes           String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(3)

  devices         DeviceConsumable[]

  @@index([name])
  @@index([quantity])
  @@map("consumables")
}

model DeviceConsumable {
  deviceId      Int
  device        Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  consumableId  Int
  consumable    Consumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)

  @@id([deviceId, consumableId])
  @@map("device_consumables")
}
