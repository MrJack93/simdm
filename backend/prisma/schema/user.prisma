model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  username            String    @unique
  passwordHash        String
  fullName            String?
  role                UserRole  @default(BIOINGINER)
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?            @db.Timestamptz(3)
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?            @db.Timestamptz(3)
  createdAt           DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @db.Timestamptz(3)

  sectionId           Int?
  section             Section?  @relation(fields: [sectionId], references: [id])

  devicesCreated      Device[]            @relation("DeviceCreatedBy")
  maintenanceRecords  MaintenanceRecord[] @relation("MaintenanceBy")
  incidentsReported   Incident[]          @relation("IncidentReportedBy")
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime             @db.Timestamptz(3)
  revokedAt   DateTime?            @db.Timestamptz(3)
  replacedBy  String?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime             @default(now()) @db.Timestamptz(3)

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model Section {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  code        String?   @unique
  floor       String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  devices     Device[]
  users       User[]
  incidents   Incident[]

  @@map("sections")
}
